generator client {
    provider = "prisma-client"
    output   = "./generated"
}

datasource db {
    provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum ThemeMode {
    light
    dark
    system
}

enum UserRole {
    admin
    staff
    doctor
    patient
}

enum UserStatus {
    pending
    active
    suspended
}

enum OtpType {
    numericCode
    secureToken
}

enum OtpPurpose {
    setPassword
    resetPassword
    updatePassword
    verifyIdentifier
    updateIdentifier
    enableMfa
    disableMfa
    updateMfa
    verifyMfa
}

enum MfaMethod {
    email
    sms
    whatsapp
    authApp
}

enum SessionStatus {
    active
    revoked
    expired
}

enum AuditAction {
    create
    update
    delete
    login
    logout
    statusChange
}

enum PushProvider {
    fcm
    expo
}

enum NotificationChannel {
    push
    email
    sms
    whatsapp
}

enum NotificationStatus {
    pending
    partial
    sent
    failed
}

enum NotificationPurpose {
    signUp
    signIn
    verifyMfa
    updateMfa
    updatePassword
    verifyIdentifier
    updateIdentifier
    userStatus
    securityAlert

    orderStatus
    refundStatus
    paymentStatus
    appointmentStatus
    appointmentReminder

    sessionNoteAdded
    treatmentPlanUpdated
    authorizationAlert

    campaign
    newChatMessage

    newsletter
    contactMessage
}

enum MediaType {
    avatar
    document
    prescription
    product
    other
}

enum MediaVisibility {
    private
    public
}

enum ContactMessageStatus {
    pending
    replied
}

enum Weekday {
    monday
    tuesday
    wednesday
    thursday
    friday
    saturday
    sunday
}

enum Gender {
    male
    female
    other
}

enum IdentificationType {
    nationalId
    passport
    driversLicense
    other
}

enum AppointmentChannel {
    inPerson
    virtual
}

enum AppointmentStatus {
    booked
    confirmed
    cancelled
    completed
    noShow
}

enum AppointmentCancellationSource {
    patient
    doctor
    admin
    staff
}

enum BookingSource {
    app
    admin
}

enum ConversationType {
    support
    appointment
}

enum ConversationStatus {
    open
    closed
}

enum PaymentProvider {
    stripe
    paypal
    manual
}

enum PaymentMethodType {
    card
    wallet
    bankTransfer
    cash
}

enum PaymentStatus {
    pending
    succeeded
    failed
    refunded
}

enum RefundStatus {
    pending
    processed
    rejected
}

enum CampaignStatus {
    draft
    scheduled
    sent
    failed
}

enum CampaignAudience {
    allUsers
    patients
    doctors
    staff
    custom
}

enum DoctorVerificationStatus {
    pending
    verified
    rejected
}

// ── E-Commerce ─────────────────────────────────────────────

enum OrderStatus {
    pending
    processing
    shipped
    delivered
    cancelled
    refunded
}

enum DeliveryType {
    delivery
    pickup
}

enum ProductStatus {
    draft
    active
    archived
}

enum InventoryStatus {
    inStock
    lowStock
    outOfStock
}

enum ShipmentStatus {
    pending
    processing
    shipped
    inTransit
    delivered
    failed
    cancelled
}

// ── ABA Clinical ───────────────────────────────────────────

enum TreatmentPlanStatus {
    draft
    active
    completed
    discontinued
}

enum ProgramType {
    skillAcquisition
    behaviorReduction
}

enum ProgramStatus {
    active
    mastered
    onHold
    discontinued
}

enum DataRecordingType {
    discreteTrial
    intervalRecording
    frequencyRate
    duration
}

enum DataResponse {
    correct
    incorrect
    prompted
    noResponse
}

enum ProgressReportStatus {
    draft
    published
}

enum InsuranceAuthorizationStatus {
    active
    expired
    exhausted
}

// ============================================================
// CORE MODELS
// ============================================================

model User {
    id String @id @default(ulid())

    avatarId String?
    avatar   Media?  @relation("UserAvatar", fields: [avatarId], references: [id], onDelete: SetNull)

    firstName   String
    lastName    String?
    displayName String
    password    String? @db.VarChar(255)

    email String? @unique @db.VarChar(255)
    phone String? @unique @db.VarChar(20)

    isEmailVerified Boolean @default(false)
    isPhoneVerified Boolean @default(false)

    role   UserRole
    status UserStatus @default(pending)

    preferredTheme    ThemeMode @default(system)
    pushNotifications Boolean   @default(false)

    preferredMfa MfaMethod?
    loginAlerts  Boolean    @default(true)
    lastLoginAt  DateTime?

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Profiles
    patientProfile PatientProfile?
    doctorProfile  DoctorProfile?
    staffProfile   StaffProfile?

    // Auth
    otps               Otp[]
    sessions           Session[]
    auditLogs          AuditLog[]
    notifications      Notification[]
    campaignRecipients CampaignRecipient[]

    // Media & messaging
    uploads      Media[]   @relation("UserUploads")
    sentMessages Message[] @relation("MessageSender")

    // Appointments
    createdAppointments Appointment[] @relation("AppointmentCreatedBy")

    // Campaigns
    createdCampaigns NotificationCampaign[] @relation("CampaignCreatedBy")

    // Doctor admin
    createdDoctorProfiles  DoctorProfile[] @relation("DoctorProfileCreatedBy")
    verifiedDoctorProfiles DoctorProfile[] @relation("DoctorProfileVerifiedBy")

    // Chat
    assignedConversations Conversation[] @relation("ConversationAssignedTo")

    // Payments
    processedRefunds Refund[] @relation("RefundProcessedBy")

    // E-commerce
    cartItems CartItem[]
    orders    Order[]

    // ABA Clinical
    createdTreatmentPlans    TreatmentPlan[]   @relation("TreatmentPlanCreatedBy")
    therapistSessionNotes    SessionNote[]     @relation("SessionNoteTherapist")
    generatedReports         ProgressReport[]  @relation("ProgressReportGeneratedBy")
    staffAssignments         StaffAssignment[] @relation("StaffAssignmentStaff")
    assignedByAssignments    StaffAssignment[] @relation("StaffAssignmentAssignedBy")
    caregiverAccesses        CaregiverAccess[] @relation("CaregiverAccessUser")
    grantedCaregiverAccesses CaregiverAccess[] @relation("CaregiverAccessGrantedBy")

    @@index([role])
    @@index([status])
    @@index([deletedAt])
}

model Session {
    id String @id @default(ulid())

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    refreshTokenHash String
    status           SessionStatus @default(active)

    ip       String
    location String
    isp      String?
    timezone String

    deviceId   String
    deviceType String
    deviceInfo String

    isTrusted  Boolean   @default(false)
    lastSeenAt DateTime?

    pushProvider PushProvider?
    pushToken    String?

    createdAt DateTime  @default(now())
    expiresAt DateTime
    revokedAt DateTime?

    @@unique([userId, deviceId])
    @@index([expiresAt])
    @@index([userId, status])
    @@index([expiresAt, status])
}

model Otp {
    id String @id @default(ulid())

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    purpose OtpPurpose
    type    OtpType    @default(numericCode)
    secret  String
    meta    Json?

    expiresAt DateTime
    usedAt    DateTime?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    @@index([userId, purpose])
    @@index([expiresAt])
}

model AuditLog {
    id String @id @default(ulid())

    userId String?
    user   User?   @relation(fields: [userId], references: [id])

    action AuditAction

    entityType String
    entityId   String

    meta Json?

    ip        String?
    userAgent String?

    createdAt DateTime @default(now())

    @@index([userId])
    @@index([entityType, entityId])
    @@index([createdAt])
}

model Notification {
    id String @id @default(ulid())

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    title     String
    message   String
    recipient String
    meta      Json?

    purpose  NotificationPurpose
    channels NotificationChannel[]
    status   NotificationStatus    @default(pending)

    readAt    DateTime?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    @@index([userId, readAt])
}

model NotificationCampaign {
    id String @id @default(ulid())

    createdById String
    createdBy   User   @relation("CampaignCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

    title   String
    subject String?
    message String
    channel NotificationChannel

    audience CampaignAudience
    status   CampaignStatus   @default(draft)

    scheduledAt DateTime?
    sentAt      DateTime?

    recipients CampaignRecipient[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([status, scheduledAt])
}

model CampaignRecipient {
    id String @id @default(ulid())

    campaignId String
    campaign   NotificationCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    sentAt DateTime?

    @@unique([campaignId, userId])
}

model Media {
    id String @id @default(ulid())

    uploadedById String
    uploadedBy   User   @relation("UserUploads", fields: [uploadedById], references: [id])

    productId String?
    product   Product? @relation("ProductImages", fields: [productId], references: [id], onDelete: SetNull)

    publicId     String @unique
    url          String @unique
    mimeType     String
    resourceType String
    size         Int
    hash         String @unique

    name       String
    altText    String?
    type       MediaType
    visibility MediaVisibility @default(private)
    notes      String?

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    messageAttachments MessageAttachment[]

    users                          User[]            @relation("UserAvatar")
    businessLogos                  BusinessProfile[] @relation("BusinessLogo")
    businessCovers                 BusinessProfile[] @relation("BusinessCoverImage")
    businessFavIcons               BusinessProfile[] @relation("BusinessFavicon")
    patientIdentificationDocuments PatientProfile[]  @relation("PatientIdentificationDocument")
    doctorLicenseDocuments         DoctorProfile[]   @relation("DoctorLicenseDocument")

    @@index([name])
    @@index([type])
    @@index([uploadedById])
    @@index([createdAt])
    @@index([deletedAt])
}

// ============================================================
// PROFILES
// ============================================================

model PatientProfile {
    id String @id @default(ulid())

    userId String @unique
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    identificationDocumentId String?
    identificationDocument   Media?  @relation("PatientIdentificationDocument", fields: [identificationDocumentId], references: [id], onDelete: SetNull)

    birthDate DateTime
    gender    Gender

    address    String?
    occupation String?

    emergencyContactName   String?
    emergencyContactNumber String? @db.VarChar(20)

    insuranceProvider     String?
    insurancePolicyNumber String?

    allergies            String?
    currentMedication    String?
    familyMedicalHistory String?
    pastMedicalHistory   String?

    identificationType   IdentificationType?
    identificationNumber String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Existing relations
    appointments  Appointment[]
    conversations Conversation[] @relation("PatientConversations")

    // ABA Clinical relations
    treatmentPlans          TreatmentPlan[]
    sessionNotes            SessionNote[]
    staffAssignments        StaffAssignment[]
    insuranceAuthorizations InsuranceAuthorization[]
    progressReports         ProgressReport[]
    caregiverAccesses       CaregiverAccess[]        @relation("CaregiverAccessPatient")
}

model DoctorProfile {
    id String @id @default(ulid())

    userId String @unique
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    branchId String
    branch   Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)

    createdById String?
    createdBy   User?   @relation("DoctorProfileCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

    verifiedById String?
    verifiedBy   User?   @relation("DoctorProfileVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)

    licenseDocumentId String?
    licenseDocument   Media?  @relation("DoctorLicenseDocument", fields: [licenseDocumentId], references: [id], onDelete: SetNull)

    slug      String  @unique
    title     String
    specialty String
    bio       String?

    licenseNumber   String   @unique
    yearsExperience Int?
    education       String?
    qualifications  String?
    languages       String[] @default([])

    consultationFee   Decimal  @db.Decimal(10, 2)
    commissionPercent Decimal? @db.Decimal(5, 2)

    verificationStatus DoctorVerificationStatus @default(pending)
    verifiedAt         DateTime?
    rejectionReason    String?

    isAvailable Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    availabilityRules DoctorAvailability[]
    blockedSlots      DoctorBlockedTime[]
    appointments      Appointment[]
    treatmentPlans    TreatmentPlan[]

    @@index([branchId])
    @@index([verificationStatus])
    @@index([isAvailable])
}

model StaffProfile {
    id String @id @default(ulid())

    userId String @unique
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    branchId String
    branch   Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)

    // e.g. "RBT", "BCBA", "BCaBA", "Program Manager"
    title       String
    specialty   String?
    bio         String?
    credentials String[] @default([])

    isActive Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([branchId])
    @@index([isActive])
}

// ============================================================
// SCHEDULING
// ============================================================

model DoctorAvailability {
    id String @id @default(ulid())

    doctorId String
    doctor   DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

    weekday   Weekday
    startTime String
    endTime   String

    slotDurationMinute Int     @default(30)
    isActive           Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([doctorId, weekday, startTime, endTime])
    @@index([doctorId, weekday, isActive])
}

model DoctorBlockedTime {
    id String @id @default(ulid())

    doctorId String
    doctor   DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

    startAt DateTime
    endAt   DateTime
    reason  String?

    createdAt DateTime @default(now())

    @@index([doctorId, startAt, endAt])
}

model Appointment {
    id                String @id @default(ulid())
    appointmentNumber String @unique

    branchId String
    branch   Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)

    patientId String
    patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Restrict)

    doctorId String
    doctor   DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Restrict)

    createdById String?
    createdBy   User?   @relation("AppointmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

    status             AppointmentStatus              @default(booked)
    cancellationSource AppointmentCancellationSource?
    bookingSource      BookingSource                  @default(app)
    channel            AppointmentChannel             @default(inPerson)

    paymentStatus PaymentStatus @default(pending)

    scheduledStartAt DateTime
    scheduledEndAt   DateTime
    timezone         String

    patientNotes       String?
    doctorNotes        String?
    adminNotes         String?
    cancellationReason String?

    bookedAt       DateTime  @default(now())
    confirmedAt    DateTime?
    cancelledAt    DateTime?
    completedAt    DateTime?
    paidAt         DateTime?
    reminderSentAt DateTime?

    payments     Payment[]
    conversation Conversation?
    sessionNote  SessionNote?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([branchId, scheduledStartAt])
    @@index([doctorId, scheduledStartAt])
    @@index([patientId, scheduledStartAt])
    @@index([status, scheduledStartAt])
}

// ============================================================
// COMMUNICATION
// ============================================================

model Conversation {
    id String @id @default(ulid())

    branchId String?
    branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

    patientId String
    patient   PatientProfile @relation("PatientConversations", fields: [patientId], references: [id], onDelete: Cascade)

    appointmentId String?      @unique
    appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

    assignedToId String?
    assignedTo   User?   @relation("ConversationAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

    type    ConversationType
    status  ConversationStatus @default(open)
    subject String?

    lastMessageAt DateTime?

    messages Message[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([branchId, type, status])
    @@index([patientId, status])
    @@index([assignedToId, status])
}

model Message {
    id String @id @default(ulid())

    conversationId String
    conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

    senderId String
    sender   User   @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

    body   String?
    readAt DateTime?

    attachments MessageAttachment[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([conversationId, createdAt])
    @@index([senderId])
}

model MessageAttachment {
    id String @id @default(ulid())

    messageId String
    message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

    mediaId String
    media   Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())

    @@unique([messageId, mediaId])
    @@index([messageId])
    @@index([mediaId])
}

// ============================================================
// PAYMENTS
// ============================================================

model Payment {
    id String @id @default(ulid())

    appointmentId String?
    appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

    orderId String?
    order   Order?  @relation(fields: [orderId], references: [id], onDelete: Cascade)

    provider   PaymentProvider
    methodType PaymentMethodType
    status     PaymentStatus     @default(pending)

    amount Decimal @db.Decimal(10, 2)

    transactionId  String?
    failureMessage String?

    paidAt     DateTime?
    refundedAt DateTime?

    metadata Json?

    commissionAmount Decimal? @db.Decimal(10, 2)
    doctorNetAmount  Decimal? @db.Decimal(10, 2)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    refunds Refund[]

    @@index([appointmentId, createdAt])
    @@index([orderId, createdAt])
    @@index([status, createdAt])
    @@index([transactionId])
}

model Refund {
    id String @id @default(ulid())

    paymentId String
    payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

    processedById String?
    processedBy   User?   @relation("RefundProcessedBy", fields: [processedById], references: [id], onDelete: SetNull)

    amount   Decimal      @db.Decimal(10, 2)
    reason   String?
    status   RefundStatus @default(pending)
    metadata Json?

    requestedAt DateTime  @default(now())
    processedAt DateTime?

    @@index([paymentId, status])
}

// ============================================================
// BUSINESS
// ============================================================

model ContactMessage {
    id String @id @default(ulid())

    trafficSourceId String?
    trafficSource   TrafficSource? @relation(fields: [trafficSourceId], references: [id])

    firstName String
    lastName  String?

    email String @db.VarChar(255)
    phone String @db.VarChar(20)

    subject String?
    message String

    status ContactMessageStatus @default(pending)
    notes  String?

    viewedAt  DateTime?
    repliedAt DateTime?

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    @@index([email])
    @@index([status])
    @@index([createdAt])
}

model NewsletterSubscriber {
    id String @id @default(ulid())

    trafficSourceId String?
    trafficSource   TrafficSource? @relation(fields: [trafficSourceId], references: [id])

    name  String
    email String @unique @db.VarChar(255)

    isActive Boolean @default(true)

    subscribedAt   DateTime  @default(now())
    unsubscribedAt DateTime?

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    @@index([email])
    @@index([createdAt])
    @@index([isActive])
}

model TrafficSource {
    id String @id @default(ulid())

    utmSource   String?
    utmMedium   String?
    utmCampaign String?
    utmTerm     String?
    utmContent  String?

    referrer    String?
    landingPage String?

    ip        String?
    userAgent String?

    createdAt DateTime @default(now())

    contactMessages ContactMessage[]
    newsletterSubs  NewsletterSubscriber[]
}

model BranchTiming {
    id       String @id @default(ulid())
    branchId String
    branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

    weekday   Weekday
    openTime  String
    closeTime String
    isClosed  Boolean @default(false)

    @@unique([branchId, weekday])
}

model Branch {
    id String @id @default(ulid())

    businessProfileId String
    businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

    name String
    slug String @unique

    email    String  @db.VarChar(255)
    phone    String  @db.VarChar(20)
    whatsapp String? @db.VarChar(20)

    street     String
    city       String
    state      String
    postalCode String
    country    String

    latitude  Decimal? @db.Decimal(10, 7)
    longitude Decimal? @db.Decimal(10, 7)

    timezone String?
    isActive Boolean @default(true)

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    branchTimings BranchTiming[]
    doctors       DoctorProfile[]
    staffMembers  StaffProfile[]
    appointments  Appointment[]
    conversations Conversation[]
    pickupOrders  Order[]        @relation("PickupOrders")

    @@index([isActive])
    @@index([city])
    @@index([country])
    @@index([businessProfileId])
    @@index([latitude, longitude])
    @@index([businessProfileId, isActive])
}

model BusinessProfile {
    id String @id @default(ulid())

    name        String
    legalName   String
    description String

    faviconId String
    favicon   Media  @relation("BusinessFavicon", fields: [faviconId], references: [id], onDelete: Restrict)

    logoId String
    logo   Media  @relation("BusinessLogo", fields: [logoId], references: [id], onDelete: Restrict)

    coverId String?
    cover   Media?  @relation("BusinessCoverImage", fields: [coverId], references: [id])

    email    String  @db.VarChar(255)
    phone    String  @db.VarChar(20)
    whatsapp String? @db.VarChar(20)
    website  String? @db.VarChar(255)

    facebook  String?
    instagram String?
    tiktok    String?
    twitter   String?
    linkedin  String?

    metaTitle       String
    metaDescription String

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    branches Branch[]
}

// ============================================================
// E-COMMERCE
// ============================================================

model ProductCategory {
    id String @id @default(ulid())

    parentId String?
    parent   ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
    children ProductCategory[] @relation("CategoryHierarchy")

    name        String
    slug        String  @unique
    description String?
    isActive    Boolean @default(true)

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    products Product[]

    @@index([isActive])
    @@index([parentId])
}

model Product {
    id String @id @default(ulid())

    categoryId String?
    category   ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

    name             String
    slug             String          @unique
    description      String?
    costPrice        Decimal         @db.Decimal(10, 2)
    sellPrice        Decimal         @db.Decimal(10, 2)
    compareAtPrice   Decimal?        @db.Decimal(10, 2)
    stockCount       Int             @default(0)
    requiresShipping Boolean         @default(true)
    status           ProductStatus   @default(draft)
    inventoryStatus  InventoryStatus @default(inStock)

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    images     Media[]     @relation("ProductImages")
    cartItems  CartItem[]
    orderItems OrderItem[]

    @@index([categoryId])
    @@index([status])
    @@index([inventoryStatus])
    @@index([deletedAt])
}

model CartItem {
    id String @id @default(ulid())

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    productId String
    product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

    quantity Int @default(1)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([userId, productId])
    @@index([userId])
}

model Order {
    id          String @id @default(ulid())
    orderNumber String @unique

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

    pickupBranchId String?
    pickupBranch   Branch? @relation("PickupOrders", fields: [pickupBranchId], references: [id], onDelete: SetNull)

    status       OrderStatus  @default(pending)
    deliveryType DeliveryType @default(delivery)

    // Shipping address (snapshot at time of order)
    shippingName       String?
    shippingPhone      String? @db.VarChar(20)
    shippingStreet     String?
    shippingCity       String?
    shippingState      String?
    shippingPostalCode String?
    shippingCountry    String?

    subtotal       Decimal @db.Decimal(10, 2)
    shippingCost   Decimal @default(0) @db.Decimal(10, 2)
    discountAmount Decimal @default(0) @db.Decimal(10, 2)
    total          Decimal @db.Decimal(10, 2)

    notes String?

    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    confirmedAt DateTime?
    shippedAt   DateTime?
    deliveredAt DateTime?
    cancelledAt DateTime?

    items     OrderItem[]
    payments  Payment[]
    shipments Shipment[]

    @@index([userId, createdAt])
    @@index([pickupBranchId])
    @@index([status, createdAt])
}

model OrderItem {
    id String @id @default(ulid())

    orderId String
    order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

    // Optional link — product may be deleted but order item persists
    productId String?
    product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

    // Snapshot of product at time of order
    productName String
    unitPrice   Decimal @db.Decimal(10, 2)
    quantity    Int
    totalPrice  Decimal @db.Decimal(10, 2)

    createdAt DateTime @default(now())

    @@index([orderId])
    @@index([productId])
}

model Shipment {
    id      String @id @default(ulid())
    orderId String
    order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

    status ShipmentStatus @default(pending)

    provider       String
    trackingNumber String
    trackingUrl    String?

    shippedAt   DateTime?
    deliveredAt DateTime?
    cancelledAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([orderId])
    @@index([status])
}

// ============================================================
// ABA CLINICAL
// ============================================================

model TreatmentPlan {
    id String @id @default(ulid())

    patientId String
    patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Restrict)

    // The BCBA or doctor who created the plan
    createdById String
    createdBy   User   @relation("TreatmentPlanCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

    // Optionally supervised by a doctor profile
    doctorId String?
    doctor   DoctorProfile? @relation(fields: [doctorId], references: [id], onDelete: SetNull)

    title       String
    description String?
    goals       String?

    status    TreatmentPlanStatus @default(draft)
    startDate DateTime?
    endDate   DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    programs                BehaviorProgram[]
    sessionNotes            SessionNote[]
    progressReports         ProgressReport[]
    insuranceAuthorizations InsuranceAuthorization[]

    @@index([patientId, status])
    @@index([createdById])
}

model BehaviorProgram {
    id String @id @default(ulid())

    treatmentPlanId String
    treatmentPlan   TreatmentPlan @relation(fields: [treatmentPlanId], references: [id], onDelete: Cascade)

    name        String
    description String?

    type   ProgramType
    status ProgramStatus @default(active)

    // Written criteria that must be met before the program is considered mastered
    masteryDefinition String?
    // Baseline data description before intervention began
    baselineData      String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    dataPoints DataPoint[]

    @@index([treatmentPlanId, status])
    @@index([type])
}

// Session notes are written by therapists after each therapy session.
// appointmentId is optional — staff can log sessions without a formal booking
// (e.g. home visits, school sessions, parent training).
model SessionNote {
    id String @id @default(ulid())

    patientId String
    patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Restrict)

    // The person who conducted the session (staff or doctor)
    therapistId String
    therapist   User   @relation("SessionNoteTherapist", fields: [therapistId], references: [id], onDelete: Restrict)

    treatmentPlanId String?
    treatmentPlan   TreatmentPlan? @relation(fields: [treatmentPlanId], references: [id], onDelete: SetNull)

    // Optional — links to a formal appointment if one was booked
    appointmentId String?      @unique
    appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

    sessionDate     DateTime
    durationMinutes Int?

    summary        String?
    clientBehavior String?
    nextSteps      String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    dataPoints DataPoint[]

    @@index([patientId, sessionDate])
    @@index([therapistId])
    @@index([treatmentPlanId])
}

// Trial-by-trial data recorded during or after a session for a specific program.
model DataPoint {
    id String @id @default(ulid())

    sessionNoteId String
    sessionNote   SessionNote @relation(fields: [sessionNoteId], references: [id], onDelete: Cascade)

    programId String
    program   BehaviorProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

    recordingType DataRecordingType
    response      DataResponse?

    // Numeric value: percentage correct, frequency count, duration in seconds, etc.
    value       Decimal? @db.Decimal(10, 4)
    trialNumber Int?
    notes       String?

    recordedAt DateTime @default(now())

    @@index([sessionNoteId])
    @@index([programId])
}

model ProgressReport {
    id String @id @default(ulid())

    patientId String
    patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Restrict)

    treatmentPlanId String?
    treatmentPlan   TreatmentPlan? @relation(fields: [treatmentPlanId], references: [id], onDelete: SetNull)

    generatedById String
    generatedBy   User   @relation("ProgressReportGeneratedBy", fields: [generatedById], references: [id], onDelete: Restrict)

    title       String
    periodStart DateTime
    periodEnd   DateTime

    // Structured report data (goals summary, session stats, program progress)
    content Json

    status ProgressReportStatus @default(draft)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([patientId, periodStart])
    @@index([treatmentPlanId])
    @@index([status])
}

// Tracks approved insurance hours per authorization period.
// usedHours is decremented manually or via session notes.
model InsuranceAuthorization {
    id String @id @default(ulid())

    patientId String
    patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Restrict)

    treatmentPlanId String?
    treatmentPlan   TreatmentPlan? @relation(fields: [treatmentPlanId], references: [id], onDelete: SetNull)

    insurancePlan       String
    authorizationNumber String

    startDate DateTime
    endDate   DateTime

    approvedHours Decimal @db.Decimal(8, 2)
    usedHours     Decimal @default(0) @db.Decimal(8, 2)

    status InsuranceAuthorizationStatus @default(active)
    notes  String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([patientId, status])
    @@index([endDate])
}

// A caregiver (parent, guardian) who is linked to view a patient's clinical data.
// The caregiver has their own User account (patient role) and is granted read
// access to a specific patient's treatment plans, session notes, and reports.
model CaregiverAccess {
    id String @id @default(ulid())

    caregiverId String
    caregiver   User   @relation("CaregiverAccessUser", fields: [caregiverId], references: [id], onDelete: Cascade)

    patientId String
    patient   PatientProfile @relation("CaregiverAccessPatient", fields: [patientId], references: [id], onDelete: Cascade)

    grantedById String
    grantedBy   User   @relation("CaregiverAccessGrantedBy", fields: [grantedById], references: [id], onDelete: Restrict)

    isActive Boolean @default(true)

    grantedAt DateTime  @default(now())
    revokedAt DateTime?

    @@unique([caregiverId, patientId])
    @@index([caregiverId, isActive])
    @@index([patientId])
}

// Assigns a staff member to a patient for caseload management.
// Admin or doctor creates the assignment. Staff can only see assigned patients.
model StaffAssignment {
    id String @id @default(ulid())

    patientId String
    patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

    staffId String
    staff   User   @relation("StaffAssignmentStaff", fields: [staffId], references: [id], onDelete: Cascade)

    assignedById String
    assignedBy   User   @relation("StaffAssignmentAssignedBy", fields: [assignedById], references: [id], onDelete: Restrict)

    isActive Boolean @default(true)
    notes    String?

    assignedAt   DateTime  @default(now())
    unassignedAt DateTime?

    @@unique([patientId, staffId])
    @@index([staffId, isActive])
    @@index([patientId])
}
